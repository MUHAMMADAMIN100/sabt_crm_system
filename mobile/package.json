{
  "name": "sabt-crm-mobile",
  "version": "1.0.0",
  "description": "Sabt CRM mobile shell — wraps the Vercel-deployed web app in Capacitor for Android/iOS.",
  "private": true,
  "scripts": {
    "init": "npx cap init \"Sabt CRM\" \"com.sabtsystem.crm\" --web-dir=www",
    "add:android": "npx cap add android",
    "add:ios": "npx cap add ios",
    "sync": "npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "build:android": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@capacitor/app": "^6.0.1",
    "@capacitor/browser": "^6.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
